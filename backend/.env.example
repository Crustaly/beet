# Beet Backend — environment variables
# Copy this to .env and fill in your values before running.

# Canton Daml JSON API (run `daml start` or `daml sandbox` to start it)
DAML_JSON_API_URL=http://localhost:7575
LEDGER_ID=beet-sandbox

# Your clinic's Canton party identifier
# Get this from `daml ledger list-parties` or the Canton console
CLINIC_PARTY=clinic::beet-sandbox

# ADI API endpoint and key (replace with real values from ADI dashboard)
ADI_API_URL=https://api.adi.example.com
ADI_API_KEY=your_adi_api_key_here

# Flask server
PORT=5000
FLASK_DEBUG=true
